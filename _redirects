# Root → Home (server-side 301, no meta refresh)
/                /Home.html               301!
# Catch-all for legacy /index.html
/index.html      /Home.html               301!

# Legal pages — pretty URL serves the .html file (rewrite, 200)
/legal/fda       /legal/fda.html          200
/es/legal/fda    /es/legal/fda.html       200

# Article .html versions → clean URLs (301 — consolidates indexation signals)
# EN articles canonical = no .html. ES articles canonical = with .html (different convention).
# Splat-based pattern: matches /articles/<anything>.html and rewrites to /articles/<anything>
/articles/*.html                  /articles/:splat             301!

# Root pages — .html versions redirect to clean URLs (301)
/Home.html                        /home                        301!
/Catalog.html                     /catalog                     301!
/Quiz.html                        /quiz                        301!
/Journal.html                     /journal                     301!
/Founder.html                     /founder                     301!
/es/Home.html                     /es/home                     301!
/es/Catalog.html                  /es/catalog                  301!
/es/Quiz.html                     /es/quiz                     301!
/es/Journal.html                  /es/journal                  301!
/es/Founder.html                  /es/founder                  301!

# Legacy product-detail URLs (Vesper era) — never existed in PuraVigor.
# GSC discovered 91 of these (May 2026 crawl); send them to the catalog so
# link equity consolidates instead of 404'ing.
# Catalog uses an in-page modal — there are no individual /p/<slug>.html files.
/p/*                              /catalog                     301!
/es/p/*                           /es/catalog                  301!
